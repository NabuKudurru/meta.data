apply.meta <- function( variable =NA , long.label =NA , full.text =NA , value.labels =NA , missing =NA , associated.ids =NA , comment =NA ){
original <- variable #make a copy
part.1 <-  as.list(strsplit(as.character(substitute(variable)), '$'))
attributes(original)$variable.label <- part.1[[length(part.1)]]
#the rest are just normal comments etc.
attributes(original)$long.label	 <- c(	long.label	)
attributes(original)$full.text	 <- c(	full.text	)
attributes(original)$value.labels	 <- c(	value.labels	)
attributes(original)$missing	 <- c(	missing	)
attributes(original)$associated.ids	 <- c(associated.ids)
attributes(original)$comment <- c(	comment)
return(original)}
write.meta.data <- function(Variable) {
part.2 <-  write.meta(Variable[,1]) # creates a template to build from (in case it has nonstandard)
for (i in 1:length(Variable)){ # for the other variables, of the length of this dataset, run below
part.1 <-  write.meta(Variable[,i]) #write meta for that variable
part.2 <- full_join(part.2, part.1)} # attach it to the others
part.3 <- apply(part.2,2,as.character)
return(part.3)}
